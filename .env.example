FIREWORKS_API_KEY=your_api_key_here
# Optional: only needed if VISION_MODEL is a google-ai/* Gemma id
GOOGLE_API_KEY=your_google_ai_studio_key_here
GOOGLE_API_TIMEOUT_S=60
# Optional: OpenRouter routing (not used by default Kimi stack)
OPENROUTER_API_KEY=your_openrouter_key_here

# Vision describe — single Kimi K2.6 + scene frames (submission default)
VISION_MODEL=accounts/fireworks/models/kimi-k2p6
VISION_ALT_MODEL=
VISION_FALLBACK_MODEL=accounts/fireworks/models/minimax-m3
DESCRIBE_DUAL=0
# Legacy dual: DESCRIBE_DUAL=1 + VISION_MODEL=minimax-m3 + VISION_ALT_MODEL=qwen3p7-plus
# Optional Gemma: VISION_MODEL=google-ai/gemma-4-26b-a4b-it (needs GOOGLE_API_KEY)
CAPTION_MODEL=accounts/fireworks/models/deepseek-v4-flash
CAPTION_MODEL_POOL=deepseek-v4-flash,deepseek-v4-flash

# Frame extraction
FRAME_MODE=scene
FRAME_INTERVAL_S=4
FRAME_COUNT_MIN=8
FRAME_COUNT_MAX=12
FRAME_WIDTH=384
FRAME_SHORT_WIDTH=512
DOWNLOAD_READ_TIMEOUT=180

# Describe
DESCRIBE_MAX_TOKENS=1400
DESCRIBE_TEMPERATURE=0.2
STRUCTURED_DESCRIBE=1

# Caption
STYLE_MAX_TOKENS=400
PARALLEL_STYLES=1
OVERLAP_PIPELINE=1
PREFETCH_DEPTH=2

# Deadline guard: 0 = off (local). Docker sets ~540.
TIME_BUDGET_S=0
DEADLINE_RESERVE_S=30

# LLM-as-judge eval (local only; not used in submission Docker)
JUDGE_MODEL=accounts/fireworks/models/gpt-oss-120b
JUDGE_MIN_SCORE=0.9
JUDGE_SLEEP_MS=400
JUDGE_RETRY=0
JUDGE_RETRY_RESERVE_S=18
JUDGE_RETRY_MAX_PER_STYLE=2
JUDGE_RETRY_QUALITY_MIN=0.9
CAPTION_POOL_TEMP_DELTA=0.15
# off | 1/all | humor | fail — Docker submission uses humor
CAPTION_VISION_ACCURACY=0

# API + failure handling
API_TIMEOUT_S=60
DESCRIBE_MAX_ATTEMPTS=2
DESCRIBE_RETRY_SLEEP_S=1.5
RETRY_JITTER_S=0.5
STYLE_MAX_ATTEMPTS=3
STYLE_META_LEAK_SALVAGE=1
STYLE_COMPRESS_ON_LONG=1
STYLE_JSON_MODE=1
VERBOSE_LOGS=1
STRUCTURED_LOGS=1
FRIENDLY_FAILURES=0
