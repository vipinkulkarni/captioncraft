FIREWORKS_API_KEY=your_api_key_here

# Submission config (Gemma prize + DeepSeek caption)
VISION_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it
CAPTION_MODEL=accounts/fireworks/models/deepseek-v4-flash

# Frame extraction (fixed count today; longer eval videos may need dynamic scaling)
FRAME_COUNT=8
FRAME_WIDTH=512
DOWNLOAD_READ_TIMEOUT=180

# Describe (Gemma needs high budget — do not inherit MAX_TOKENS from caption env)
DESCRIBE_MAX_TOKENS=1000
DESCRIBE_TEMPERATURE=0.2

# Caption
STYLE_MAX_TOKENS=400
PARALLEL_STYLES=0

# Fallback serverless vision (not used in submission)
# VISION_MODEL=accounts/fireworks/models/minimax-m3
