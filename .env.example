FIREWORKS_API_KEY=your_api_key_here

# Submission config (serverless M3 vision + DeepSeek caption)
VISION_MODEL=accounts/fireworks/models/minimax-m3
CAPTION_MODEL=accounts/fireworks/models/deepseek-v4-flash

# Frame extraction (dynamic by duration; set FRAME_COUNT to force a fixed count)
FRAME_INTERVAL_S=4
FRAME_COUNT_MIN=8
FRAME_COUNT_MAX=24
# FRAME_COUNT=8
FRAME_WIDTH=384
DOWNLOAD_READ_TIMEOUT=180

# Describe (vision models need high budget)
DESCRIBE_MAX_TOKENS=1200
DESCRIBE_TEMPERATURE=0.2
# 1 = JSON describe schema (default); 0 = legacy prose describe prompt
STRUCTURED_DESCRIBE=1

# Caption
STYLE_MAX_TOKENS=400
# 1 = parallel style calls (Docker default, ~17% faster on full eval); 0 = sequential (debug/reliability)
PARALLEL_STYLES=1

# LLM-as-judge eval (local only; not used in submission Docker)
JUDGE_MODEL=accounts/fireworks/models/gpt-oss-120b
# Comma-separated panel for bake-offs and final decisions (--panel in score_results.py)
# JUDGE_MODELS=accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/kimi-k2-6,accounts/fireworks/models/glm-5-1
JUDGE_MIN_SCORE=3
JUDGE_SLEEP_MS=400

# API + failure handling
API_TIMEOUT_S=45
DESCRIBE_MAX_ATTEMPTS=2
DESCRIBE_RETRY_SLEEP_S=1.5
RETRY_JITTER_S=0.5
STYLE_MAX_ATTEMPTS=3
# 1 = human-readable stderr progress lines (default on); 0 = JSON-only logs
VERBOSE_LOGS=1
# 1 = one JSON line per clip on stderr (default on)
STRUCTURED_LOGS=1
# 1 = neutral fallback captions in results.json (Docker default); 0 = raw error strings for local debug
FRIENDLY_FAILURES=0
