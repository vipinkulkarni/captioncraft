FIREWORKS_API_KEY=your_api_key_here

# Submission config (Option A: serverless M3 vision + DeepSeek caption)
VISION_MODEL=accounts/fireworks/models/minimax-m3
CAPTION_MODEL=accounts/fireworks/models/deepseek-v4-flash

# Frame extraction (dynamic by duration; set FRAME_COUNT to force a fixed count)
FRAME_INTERVAL_S=4
FRAME_COUNT_MIN=8
FRAME_COUNT_MAX=24
# FRAME_COUNT=8
FRAME_WIDTH=512
DOWNLOAD_READ_TIMEOUT=180

# Describe (vision models need high budget — do not inherit MAX_TOKENS from caption env)
DESCRIBE_MAX_TOKENS=1000
DESCRIBE_TEMPERATURE=0.2

# Caption
STYLE_MAX_TOKENS=400
PARALLEL_STYLES=0

