FIREWORKS_API_KEY=your_api_key_here
# Google AI Studio (direct Gemma 4 vision — recommended over OpenRouter free tier)
GOOGLE_API_KEY=your_google_ai_studio_key_here
# Google AI Studio describe (Gemma 4 uses thinking; MINIMAL + 2048 output tokens)
# GOOGLE_DESCRIBE_MAX_TOKENS=2048
# Per-request timeout for Google AI calls; hung calls fail into the fallback
GOOGLE_API_TIMEOUT_S=60
# Optional: OpenRouter fallback if you prefer hosted routing
OPENROUTER_API_KEY=your_openrouter_key_here

# Vision describe — parallel dual (M3 ∥ Qwen3.7 Plus) + cross-judge pick-best
VISION_MODEL=accounts/fireworks/models/minimax-m3
VISION_ALT_MODEL=accounts/fireworks/models/qwen3p7-plus
VISION_FALLBACK_MODEL=accounts/fireworks/models/qwen3p7-plus
DESCRIBE_DUAL=1
# Optional legacy single-model: set DESCRIBE_DUAL=0 and VISION_MODEL only
# VISION_MODEL=google-ai/gemma-4-26b-a4b-it
# Caption: DeepSeek solo (no best-of-N pool)
CAPTION_MODEL=accounts/fireworks/models/deepseek-v4-flash
# Best-of-2: two parallel DeepSeek samples per style; regex picks the cleaner one.
CAPTION_MODEL_POOL=deepseek-v4-flash,deepseek-v4-flash

# Frame extraction (dynamic by duration; set FRAME_COUNT to force a fixed count)
FRAME_INTERVAL_S=4
FRAME_COUNT_MIN=8
FRAME_COUNT_MAX=24
# FRAME_COUNT=8
FRAME_WIDTH=384
DOWNLOAD_READ_TIMEOUT=180

# Describe (vision models need high budget)
DESCRIBE_MAX_TOKENS=1200
DESCRIBE_TEMPERATURE=0.2
# 1 = JSON describe schema (default); 0 = legacy prose describe prompt
STRUCTURED_DESCRIBE=1

# Caption
STYLE_MAX_TOKENS=400
# 1 = parallel style calls (Docker default, ~17% faster on full eval); 0 = sequential (debug/reliability)
PARALLEL_STYLES=1
# 1 = overlap next clip describe while current clip is captioning (default on)
OVERLAP_PIPELINE=1
# Background download slots for upcoming clips (streamed to disk, memory-flat)
PREFETCH_DEPTH=2

# Deadline guard: 0 = off (local). Docker sets ~540 (10 min limit minus buffer).
# When remaining budget < DEADLINE_RESERVE_S x remaining clips, describes skip
# the primary vision model and go straight to VISION_FALLBACK_MODEL.
TIME_BUDGET_S=0
DEADLINE_RESERVE_S=30

# LLM-as-judge eval (local only; not used in submission Docker)
JUDGE_MODEL=accounts/fireworks/models/gpt-oss-120b
# Comma-separated panel for bake-offs and final decisions (--panel in score_results.py)
# JUDGE_MODELS=accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/glm-5p1,accounts/fireworks/models/deepseek-v4-flash
JUDGE_MIN_SCORE=0.9
JUDGE_SLEEP_MS=400
# Post-pass: judge all captions, re-caption failures while TIME_BUDGET allows
JUDGE_RETRY=0
JUDGE_RETRY_RESERVE_S=18
JUDGE_RETRY_MAX_PER_STYLE=2
JUDGE_RETRY_QUALITY_MIN=0.9
# Best-of-N pool: second candidate temperature = style base + delta
CAPTION_POOL_TEMP_DELTA=0.15

# API + failure handling
API_TIMEOUT_S=45
DESCRIBE_MAX_ATTEMPTS=2
DESCRIBE_RETRY_SLEEP_S=1.5
RETRY_JITTER_S=0.5
STYLE_MAX_ATTEMPTS=3
# 1 = one extra low-temp retry after repeated MetaLeak failures (default on)
STYLE_META_LEAK_SALVAGE=1
# 1 = LLM rewrite pass when output is TooLong (default on; prefer over blind truncation)
STYLE_COMPRESS_ON_LONG=1
# 1 = first attempt uses JSON {"caption": "..."} (optional; off by default)
STYLE_JSON_MODE=1
# 1 = human-readable stderr progress lines (default on); 0 = JSON-only logs
VERBOSE_LOGS=1
# 1 = one JSON line per clip on stderr (default on)
STRUCTURED_LOGS=1
# 1 = neutral fallback captions in results.json (Docker default); 0 = raw error strings for local debug
FRIENDLY_FAILURES=0
